GMAIL_USER=
GMAIL_APP_PASSWORD=
SESSION_SECRET=

# Responders - add as many numbered blocks as you need (1, 2, 3, ...).
# The number is just a slot in .env; the "username" field is the actual
# login name whoever's using this dashboard will type in.
RESPONDER_1_USERNAME=A
RESPONDER_1_PASSWORD=
RESPONDER_1_EMAIL=

RESPONDER_2_USERNAME=B
RESPONDER_2_PASSWORD=
RESPONDER_2_EMAIL=

# To add responder C, uncomment and fill these in - no code changes needed:
# RESPONDER_3_USERNAME=
# RESPONDER_3_PASSWORD=
# RESPONDER_3_EMAIL=